---
import { type Lang, t, localePath } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const s = t(lang);
---

<footer class="mt-24 px-5 sm:px-8 py-12" style="border-top:1px solid #18243F; background:#0C1424;">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <!-- Left -->
      <div>
        <img src="/logo.svg" alt="NiQuit" class="h-7 w-auto mb-3 opacity-80" />
        <p class="text-sm" style="color:#B0B8C8;">{s.footer.tagline}</p>
      </div>

      <!-- Links -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm" style="color:#B0B8C8;">
        <a href={localePath(lang, 'privacy')} class="hover:text-white transition-colors">{s.footer.privacy}</a>
        <a href={localePath(lang, 'terms')} class="hover:text-white transition-colors">{s.footer.terms}</a>
        <span class="flex items-center gap-2">
          <a href="mailto:hello@niquit.app" class="hover:text-white transition-colors">{s.footer.contact}</a>
          <span style="color:#6B7A8D; font-size:0.8em;">hello@niquit.app</span>
        </span>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 flex justify-end">
      <p class="text-xs" style="color:#B0B8C8;">
        &copy; {new Date().getFullYear()} NiQuit
      </p>
    </div>
  </div>
</footer>
