---
import Base from '../../layouts/Base.astro';
import BlogCard from '../BlogCard.astro';
import DonateSection from '../DonateSection.astro';
import { type Lang, t, localePath } from '../../i18n/ui';
import { getCollection } from 'astro:content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const s = t(lang);

const heroScreenshot: Record<Lang, string> = {
  en: '/img/EN/1.jpg',
  ru: '/img/RU/3.jpg',
  de: '/img/DE/4.jpg',
  es: '/img/ES/4.jpg',
  fr: '/img/FR/4.jpg',
};

const allPosts = await getCollection('blog', (entry) =>
  entry.data.lang === lang && !entry.data.draft
);
const posts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<Base title={s.hero.headline} lang={lang} description={s.hero.sub}>

  <!-- Hero: 2-col on desktop (text left, phone right), single col on mobile -->
  <section
    class="min-h-[75vh] py-20 px-6 md:px-12"
    style="background:radial-gradient(120% 100% at 80% 0%, #12275A 0%, #0A1A33 55%);"
  >
  <div class="max-w-5xl mx-auto grid gap-8 items-center md:grid-cols-[1.05fr_0.95fr]">
    <!-- Left: text -->
    <div>
      <span
        class="inline-block mb-6 text-xs px-3 py-1.5 rounded-full border"
        style="font-family:'JetBrains Mono',monospace; color:#67E8F9; border-color:rgba(53,198,216,0.3);"
      >
        {s.hero.label}
      </span>

      <h1
        class="font-extrabold leading-[1.02] text-[40px] md:text-6xl"
        style="font-family:'Space Grotesk',sans-serif; color:#EAF1FF; letter-spacing:-0.025em;"
      >
        {s.hero.prefix} <span class="nicotine">{s.hero.nicotine}</span><br />{s.hero.suffix}
      </h1>

      <p class="mt-6 max-w-[460px] text-lg leading-relaxed" style="color:#CBD5E1;">
        {s.hero.sub}
      </p>

      <a
        href="https://play.google.com/store/apps/details?id=com.niquit.app"
        target="_blank"
        rel="noopener"
        data-ph-install="hero"
        class="inline-block mt-8 rounded-xl px-7 py-4 font-bold transition-opacity hover:opacity-90"
        style="background:#FF6B5C; color:#0A1A33; font-family:'Space Grotesk',sans-serif;"
      >
        {s.hero.cta}
      </a>
    </div>

    <!-- Right: phone mockup -->
    <div class="flex justify-center">
      <div class="phone">
        <img
          src={heroScreenshot[lang]}
          alt="NiQuit"
          loading="eager"
        />
      </div>
    </div>
  </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-5 sm:px-8" style="background:#18243F;">
    <div class="max-w-5xl mx-auto">
      <h2
        class="text-2xl sm:text-3xl font-extrabold mb-10 text-center"
        style="font-family:'Montserrat',sans-serif; color:#F5F7FA;"
      >
        {s.features.title}
      </h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { icon: '📖', ...s.features.course },
          { icon: '🌱', ...s.features.health },
          { icon: '💬', ...s.features.coach },
          { icon: '💰', ...s.features.savings },
          { icon: '🎯', ...s.features.multiSource },
        ].map(({ icon, title, desc }) => (
          <div class="rounded-2xl p-7" style="background:#0C1424;">
            <div class="text-3xl mb-4">{icon}</div>
            <h3
              class="text-lg font-bold mb-2"
              style="font-family:'Montserrat',sans-serif; color:#F5F7FA;"
            >
              {title}
            </h3>
            <p class="text-sm leading-relaxed" style="color:#B0B8C8;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog preview -->
  <section class="py-20 px-5 sm:px-8">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2
          class="text-2xl sm:text-3xl font-extrabold"
          style="font-family:'Montserrat',sans-serif; color:#F5F7FA;"
        >
          {s.blog.title}
        </h2>
        <a href={localePath(lang, 'blog')} class="text-sm font-semibold" style="color:#22D3EE;">
          {s.blog.readMore} &rarr;
        </a>
      </div>

      {posts.length === 0 ? (
        <p style="color:#B0B8C8;">{s.blog.empty}</p>
      ) : (
        <div class="grid sm:grid-cols-3 gap-6">
          {posts.map((post) => (
            <BlogCard
              lang={lang}
              title={post.data.title}
              description={post.data.description}
              slug={post.id.split('/').pop()}
              publishDate={post.data.publishDate}
              heroImage={post.data.heroImage}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Donate -->
  <DonateSection lang={lang} />

</Base>
