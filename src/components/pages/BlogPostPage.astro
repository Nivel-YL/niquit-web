---
import { type Lang } from '../../i18n/ui';
import { getCollection, type CollectionEntry, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

interface Props {
  lang: Lang;
  entry: CollectionEntry<'blog'>;
}

const { lang, entry } = Astro.props;
const { Content } = await render(entry);

const slug = entry.id.split('/').pop() ?? entry.id;

function getCluster(s: string): string {
  if (s.includes('vap')) return 'vaping';
  if (s.includes('pouch') || s.includes('snus') || s.includes('zyn')) return 'nicotine-pouches';
  return 'nicotine-science';
}
const cluster = getCluster(slug);
---

<BlogPost
  title={entry.data.title}
  description={entry.data.description}
  publishDate={entry.data.publishDate}
  lang={lang}
  heroImage={entry.data.heroImage}
  slug={slug}
  cluster={cluster}
>
  <Content />
</BlogPost>
