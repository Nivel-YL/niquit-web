---
import { type Lang, t } from '../i18n/ui';
import { GOOGLE_URL, APPLE_URL } from '../config/stores';

interface Props {
  lang: Lang;
  size?: 'sm' | 'md' | 'lg';
  location?: 'header' | 'hero' | 'article' | 'footer';
}

const { lang, size = 'md', location = 'hero' } = Astro.props;
const s = t(lang);
const isHeader = location === 'header';

const SHOW_APPLE = true;

const classes = {
  sm:  'px-4 py-2 text-sm rounded-lg font-semibold whitespace-nowrap',
  md:  'px-5 py-3 text-sm rounded-xl font-semibold whitespace-nowrap',
  lg:  'px-7 py-4 text-base rounded-xl font-semibold whitespace-nowrap',
};

// Official Apple-hosted badge, localized per language (same badge Apple's own
// App Store Marketing Tools generator embeds: https://toolbox.marketingtools.apple.com/app-store/)
const APPLE_BADGE_LOCALE: Record<Lang, string> = {
  en: 'en-us',
  ru: 'ru-ru',
  de: 'de-de',
  es: 'es-es',
  fr: 'fr-fr',
};
const badgeHeights = {
  sm: 'h-9',
  md: 'h-11',
  lg: 'h-14',
};
const appleBadgeSrc = `https://tools.applemediaservices.com/api/badges/download-on-the-app-store/black/${APPLE_BADGE_LOCALE[lang]}?size=250x83`;
---

<div class={`flex ${isHeader ? 'gap-2 sm:gap-3' : 'gap-3'} ${size === 'lg' ? 'flex-col sm:flex-row' : 'items-center'}`}>
  {isHeader ? (
    <>
      <!-- Mobile header: quiet, compact, same scale for both, never wraps -->
      <a
        href={GOOGLE_URL}
        target="_blank"
        rel="noopener"
        data-ph-install={location}
        aria-label={s.install.google}
        class="sm:hidden inline-flex items-center h-8 px-2.5 rounded-lg text-xs font-medium whitespace-nowrap border transition-opacity hover:opacity-90"
        style="border-color:rgba(53,198,216,0.35); color:#93A6C6;"
      >
        Google Play
      </a>
      <a
        href={GOOGLE_URL}
        target="_blank"
        rel="noopener"
        data-ph-install={location}
        class={`hidden sm:inline-flex items-center ${classes.sm} transition-opacity hover:opacity-90`}
        style="background:#22D3EE; color:#0C1424;"
      >
        {s.install.google}
      </a>

      {SHOW_APPLE && (
        <>
          <a
            href={APPLE_URL}
            target="_blank"
            rel="noopener"
            data-ph-install={location}
            aria-label={s.install.apple}
            class="sm:hidden inline-flex items-center h-8 px-2.5 rounded-lg text-xs font-medium whitespace-nowrap border transition-opacity hover:opacity-90"
            style="border-color:rgba(147,166,198,0.35); color:#93A6C6;"
          >
            App Store
          </a>
          <a
            href={APPLE_URL}
            target="_blank"
            rel="noopener"
            data-ph-install={location}
            class="hidden sm:inline-flex items-center transition-opacity hover:opacity-90"
          >
            <img
              src={appleBadgeSrc}
              alt={s.install.apple}
              width="250"
              height="83"
              loading="lazy"
              class="h-9 w-auto"
              onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';"
            />
            <span
              style="display:none; background:#18243F; color:#F5F7FA; border:1px solid #22D3EE44;"
              class={`${classes.sm} items-center`}
            >
              {s.install.apple}
            </span>
          </a>
        </>
      )}
    </>
  ) : (
    <>
      <a
        href={GOOGLE_URL}
        target="_blank"
        rel="noopener"
        data-ph-install={location}
        class={`${classes[size]} transition-opacity hover:opacity-90`}
        style="background:#22D3EE; color:#0C1424;"
      >
        {s.install.google}
      </a>

      {SHOW_APPLE && (
        <a
          href={APPLE_URL}
          target="_blank"
          rel="noopener"
          data-ph-install={location}
          class="inline-flex items-center transition-opacity hover:opacity-90"
        >
          <img
            src={appleBadgeSrc}
            alt={s.install.apple}
            width="250"
            height="83"
            loading="lazy"
            class={`${badgeHeights[size]} w-auto`}
            onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';"
          />
          <span
            style="display:none; background:#18243F; color:#F5F7FA; border:1px solid #22D3EE44;"
            class={`${classes[size]} items-center`}
          >
            {s.install.apple}
          </span>
        </a>
      )}
    </>
  )}
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-ph-install]').forEach((el) => {
    el.addEventListener('click', () => {
      (window as any).posthog?.capture('install_button_clicked', {
        platform: 'website',
        location: el.dataset.phInstall,
      });
    });
  });
</script>
