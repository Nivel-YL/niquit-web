---
import { type Lang, LANGS, t, localePath } from '../i18n/ui';
import InstallButton from './InstallButton.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const s = t(lang);

const langCode: Record<string, string> = { en:'EN', ru:'RU', de:'DE', es:'ES', fr:'FR' };
const langName: Record<string, string> = {
  en: 'English', ru: 'Русский', de: 'Deutsch', es: 'Español', fr: 'Français',
};

const currentPathNoLang = Astro.url.pathname.replace(/^\/(ru|de|es|fr)(\/|$)/, '/');
const otherLangs = LANGS.filter((l) => l !== lang);
---

<header
  class="sticky top-0 z-50 flex items-center justify-between px-5 sm:px-8 h-16"
  style="background:rgba(12,20,36,0.92); backdrop-filter:blur(12px); border-bottom:1px solid #18243F;"
>
  <a href={localePath(lang)} class="flex items-center gap-2 no-underline">
    <img src="/logo.svg" alt="NiQuit" class="h-8 w-auto" />
  </a>

  <nav class="hidden sm:flex items-center gap-6 text-sm font-medium" style="color:#B0B8C8;">
    <a href={localePath(lang, 'blog')} class="hover:text-white transition-colors">{s.nav.blog}</a>
    <a href={localePath(lang, 'method')} class="hover:text-white transition-colors">{s.nav.method}</a>
    <a href={localePath(lang, 'support')} class="hover:text-white transition-colors">{s.nav.support}</a>
  </nav>

  <div class="flex items-center gap-3">
    <!-- Language switcher — JS click-based -->
    <div class="lang" data-lang-switcher>
      <button type="button" class="lang__btn" aria-haspopup="listbox" aria-expanded="false">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="#35C6D8" stroke-width="1.8" aria-hidden="true">
          <circle cx="12" cy="12" r="9"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <ellipse cx="12" cy="12" rx="4" ry="9"/>
        </svg>
        <span class="lang__code">{langCode[lang]}</span>
        <svg class="lang__caret" width="10" height="10" viewBox="0 0 12 12"
             fill="none" stroke="#93A6C6" stroke-width="1.8" aria-hidden="true">
          <path d="M2 4l4 4 4-4"/>
        </svg>
      </button>

      <ul class="lang__menu" role="listbox" hidden>
        {otherLangs.map((l) => (
          <li role="option">
            <a href={localePath(l, currentPathNoLang.replace(/^\//, ''))}>
              <b>{langCode[l]}</b>{langName[l]}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <InstallButton lang={lang} size="sm" />
  </div>
</header>

<script>
  document.querySelectorAll('[data-lang-switcher]').forEach((root) => {
    const btn  = root.querySelector('.lang__btn') as HTMLButtonElement;
    const menu = root.querySelector('.lang__menu') as HTMLElement;
    const open  = () => { menu.hidden = false; btn.setAttribute('aria-expanded', 'true'); };
    const close = () => { menu.hidden = true;  btn.setAttribute('aria-expanded', 'false'); };
    btn.addEventListener('click', (e) => { e.stopPropagation(); menu.hidden ? open() : close(); });
    menu.addEventListener('click', () => { close(); });
    document.addEventListener('click',  (e) => { if (!root.contains(e.target as Node)) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  });
</script>
