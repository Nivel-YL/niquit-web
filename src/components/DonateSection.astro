---
import { type Lang, t } from '../i18n/ui';
import { STRIPE_LINKS, STRIPE_CUSTOM_LINK, DONATE_TIERS } from '../i18n/donate';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const s = t(lang);
---

<section class="py-20 px-5 sm:px-8" id="support">
  <div class="max-w-2xl mx-auto text-center">
    <h2
      class="text-3xl sm:text-4xl font-extrabold mb-4"
      style="font-family:'Montserrat',sans-serif; color:#F5F7FA;"
    >
      {s.donate.title}
    </h2>
    <p class="text-base mb-12 max-w-lg mx-auto" style="color:#B0B8C8;">{s.donate.sub}</p>

    <!-- Tiers: large to small, no badge -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
      {DONATE_TIERS.map((amount) => (
        <a
          href={STRIPE_LINKS[String(amount)]}
          target="_blank"
          rel="noopener"
          class="rounded-xl py-4 px-3 text-center font-bold text-xl transition-opacity hover:opacity-80"
          style="background:#18243F; color:#F5F7FA; text-decoration:none;"
        >
          &euro;{amount}
        </a>
      ))}
    </div>

    <!-- Custom amount -->
    <a
      href={STRIPE_CUSTOM_LINK}
      target="_blank"
      rel="noopener"
      class="block w-full rounded-xl py-4 px-3 text-center font-semibold text-base transition-opacity hover:opacity-80"
      style="background:#18243F; color:#B0B8C8; text-decoration:none; border:1px solid #22D3EE33;"
    >
      {s.donate.custom} &rarr;
    </a>
  </div>
</section>
