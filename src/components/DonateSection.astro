---
import { type Lang, t } from '../i18n/ui';
import { STRIPE_LINKS, STRIPE_CUSTOM_LINK, DONATE_TIERS } from '../i18n/donate';

interface Props { lang: Lang; compact?: boolean; }
const { lang, compact = false } = Astro.props;
const s = t(lang);
---

<section class="py-20 px-5 sm:px-8" id="support">
  <div class="max-w-2xl mx-auto text-center">
    {!compact && (
      <>
        <h2
          class="text-3xl sm:text-4xl font-extrabold mb-4"
          style="font-family:'Montserrat',sans-serif; color:#F5F7FA;"
        >
          {s.donate.title}
        </h2>
        <p class="text-base mb-12 max-w-lg mx-auto" style="color:#B0B8C8;">{s.donate.sub}</p>
      </>
    )}

    {compact && (
      <p class="text-sm mb-6" style="color:#6B7A8D;">{s.donate.invite}</p>
    )}

    <!-- Tiers -->
    <div class="flex flex-wrap justify-center gap-3 mb-6">
      {DONATE_TIERS.map((amount) => (
        <a
          href={STRIPE_LINKS[String(amount)]}
          target="_blank"
          rel="noopener"
          data-ph-amount={String(amount)}
          class="rounded-xl py-4 px-5 text-center font-bold text-xl transition-opacity hover:opacity-80"
          style="background:#18243F; color:#F5F7FA; text-decoration:none;"
        >
          &euro;{amount}
        </a>
      ))}
    </div>

    <script>
      document.querySelectorAll<HTMLElement>('[data-ph-amount]').forEach((el) => {
        el.addEventListener('click', () => {
          (window as any).posthog?.capture('donate_tier_clicked', {
            platform: 'website',
            amount: Number(el.dataset.phAmount),
          });
        });
      });
    </script>

    <!-- Custom amount — subtle secondary action -->
    <a
      href={STRIPE_CUSTOM_LINK}
      target="_blank"
      rel="noopener"
      class="inline-block mt-2 text-sm transition-opacity hover:opacity-80"
      style="color:#B0B8C8; text-decoration:none;"
    >
      {s.donate.custom} &rarr;
    </a>
  </div>
</section>
