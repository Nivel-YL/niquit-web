---
import { type Lang, t } from '../i18n/ui';
import InstallButton from './InstallButton.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const s = t(lang);
---

<div
  class="rounded-2xl px-7 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5"
  style="background:#18243F;"
>
  <p class="text-lg font-semibold" style="color:#F5F7FA;">{s.articleCta.headline}</p>
  <InstallButton lang={lang} size="md" location="article" />
</div>
