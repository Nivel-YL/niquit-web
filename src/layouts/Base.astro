---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { type Lang, LANGS, localePath } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  ogImage?: string;
}

const { title, description = 'NiQuit: free nicotine cessation app', lang = 'en', ogImage } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://niquit.app');
const siteOrigin = (Astro.site ?? new URL('https://niquit.app')).origin;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | NiQuit</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang: tell search engines these are language variants of the same page -->
    {LANGS.map((l) => (
      <link rel="alternate" hreflang={l} href={`${siteOrigin}${localePath(l, Astro.url.pathname.replace(/^\/(ru|de|es|fr)\//, '/').replace(/^\/(ru|de|es|fr)$/, '/'))}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteOrigin}${localePath('en', Astro.url.pathname.replace(/^\/(ru|de|es|fr)\//, '/').replace(/^\/(ru|de|es|fr)$/, '/'))}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | NiQuit`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700&family=Figtree:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&family=Montserrat:wght@700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col" style="background-color:#0C1424; color:#F5F7FA;">
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
